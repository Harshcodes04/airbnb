<%- include ('partials/head') %>
  <body class="bg-gray-50 flex flex-col min-h-screen font-sans">
    <%-include ('partials/nav') %>
    <main class="grow container mx-auto px-4 py-8 max-w-lg">
      <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100">
        <h1 class="text-2xl font-bold text-gray-900 mb-6 text-center">
          Add a New Home
        </h1>

        <form action="/host/add-home" method="POST" class="space-y-4">
          <div>
            <label
              for="homeName"
              class="block text-sm font-medium text-gray-700 mb-1"
              >Home Name</label
            >
            <input
              type="text"
              name="houseName"
              id="houseName"
              placeholder="Enter home name"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
            />
            <input
              type="text"
              name="price"
              id="price"
              placeholder="Enter price per night"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
            />
            <input
              type="text"
              name="location"
              id="location"
              placeholder="Enter home location"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
            />
            <input
              type="text"
              name="rating"
              id="rating"
              placeholder="Enter home rating"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
            />
            <input
              type="text"
              name="photoUrl"
              id="image"
              placeholder="Enter image URL"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
            />
            
            
          </div>

          <button
            type="submit"
            class="w-full bg-red-500 hover:bg-[#d50027] text-white font-bold py-2 px-4 rounded-md transition duration-200"
          >
            Add Home
          </button>
        </form>
      </div>
    </main>

    <footer class="bg-white border-t border-gray-200 mt-auto">
      <div class="max-w-7xl mx-auto py-6 px-4">
        <p class="text-center text-gray-400 text-sm">
          &copy; 2025 Airbnb Clone
        </p>
      </div>
    </footer>
  </body>
</html>
