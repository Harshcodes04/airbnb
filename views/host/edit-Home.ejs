<%- include ('../partials/head') %>
  <body class="bg-gray-50 flex flex-col min-h-screen font-sans">
    <%-include ('../partials/nav') %>
    <main class="grow container mx-auto px-4 py-8 max-w-lg">
      <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100">
        <h1 class="text-2xl font-bold text-gray-900 mb-6 text-center">
          <%= editing? "Edit Home Details" : "Register A New Home" %>
        </h1>

        <form action="/host<%= editing ? '/edit-home' : '/add-home' %>" method="POST" class="space-y-4">
          <div class="mt-2 space-y-2">
            <input type="hidden" name="id" value="<%= editing? home.id:''%>"/>
            <label
              for="homeName"
              class="block text-sm font-medium text-gray-700 mb-1"
              >Home Name</label
            >
            <input
              type="text"
              name="houseName"
              id="houseName"
              value="<%= editing? home.houseName:''%>"
              placeholder="Enter home name"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
            />
            <input
              type="text"
              name="price"
              id="price"
                value="<%= editing? home.price:''%>"
              placeholder="Enter price per night"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
            />
            <input
              type="text"
              name="location"
              id="location"
                value="<%= editing? home.location:''%>"
              placeholder="Enter home location"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
            />
            <input
              type="text"
              name="rating"
              id="rating"
                value="<%= editing? home.rating:''%>"
              placeholder="Enter home rating"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
            />
            <input
              type="text"
              name="photoUrl"
              id="image"
              placeholder="Enter image URL"
                value="<%= editing? home.photoUrl:''%>"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
            />
            
            
          </div>

          <button
            type="submit"
            class="w-full bg-red-500 hover:bg-[#d50027] text-white font-bold py-2 px-4 rounded-md transition duration-200"
          >
            <%=editing? "Update Home":"Add Home"%>
          </button>
        </form>
      </div>
    </main>

   <%- include ('../partials/footer') %>
  </body>
</html>
