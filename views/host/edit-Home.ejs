<%-include ('../partials/head') %>
  <body class="bg-[#f8f9fa] flex flex-col min-h-screen">
    <%-include ('../partials/nav') %>
    
    <main class="grow container mx-auto px-4 py-12 max-w-[600px] flex items-center justify-center">
      
      <div class="bg-white p-8 sm:p-10 rounded-[32px] shadow-xl border border-gray-100/50 w-full animate-fade-in-up card-glow">
        
        <!-- Header -->
        <div class="mb-10 text-center flex flex-col items-center">
          <div class="w-16 h-16 bg-gradient-to-br from-[#FF385C] to-[#E31C5F] rounded-2xl flex items-center justify-center shadow-lg shadow-red-200 mb-5 relative transform -rotate-3 hover:rotate-3 transition-transform duration-300">
             <div class="absolute inset-0 bg-white/20 rounded-2xl"></div>
             <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">
            <%= editing ? "Edit Listing Details" : "List Your Space" %>
          </h1>
          <p class="text-gray-500 mt-2 font-medium">
            <%= editing ? "Update your home details to attract more guests." : "Tell us about your home and start earning today." %>
          </p>
        </div>

        <!-- Form -->
        <form action="/host<%= editing ? '/edit-home' : '/add-home' %>" method="POST" class="space-y-6">
          <input type="hidden" name="id" value="<%= editing ? home._id : '' %>"/>
          
          <div class="space-y-5 relative">
            
            <div class="grid grid-cols-1 gap-5">
              <!-- Home Name -->
              <div class="relative group">
                <input
                  type="text"
                  name="houseName"
                  id="houseName"
                  value="<%= editing ? home.houseName : '' %>"
                  placeholder="Name of your house "
                  required
                  class="peer w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:bg-white input-glow text-gray-900 font-medium placeholder-transparent transition-all"
                />
                <label for="houseName" class="absolute left-5 top-4 text-gray-400 font-medium transition-all peer-placeholder-shown:text-[16px] peer-placeholder-shown:top-4 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-[#FF385C] peer-focus:bg-white peer-focus:px-1 peer-valid:-top-2.5 peer-valid:text-xs peer-valid:bg-white peer-valid:px-1 z-10 rounded">
                  Home Name
                </label>
              </div>

              <!-- Location -->
              <div class="relative group">
                <input
                  type="text"
                  name="location"
                  id="location"
                  value="<%= editing ? home.location : '' %>"
                  placeholder=" Location of your house"
                  required
                  class="peer w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:bg-white input-glow text-gray-900 font-medium placeholder-transparent transition-all"
                />
                <label for="location" class="absolute left-5 top-4 text-gray-400 font-medium transition-all peer-placeholder-shown:text-[16px] peer-placeholder-shown:top-4 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-[#FF385C] peer-focus:bg-white peer-focus:px-1 peer-valid:-top-2.5 peer-valid:text-xs peer-valid:bg-white peer-valid:px-1 z-10 rounded">
                  Location 
                </label>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <!-- Price Indicator -->
              <div class="relative group">
                <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
                  <span class="text-gray-500 font-bold peer-focus:text-[#FF385C]">₹</span>
                </div>
                <input
                  type="number"
                  name="price"
                  id="price"
                  value="<%= editing ? home.price : '' %>"
                  placeholder=" Price per night"
                  required
                  step="0.01"
                  min="0"
                  class="peer w-full pl-9 pr-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:bg-white input-glow text-gray-900 font-bold placeholder-transparent transition-all"
                />
                <label for="price" class="absolute left-0 top-4 text-gray-400 font-medium transition-all peer-placeholder-shown:text-[16px] peer-placeholder-shown:top-4 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-[#FF385C] peer-focus:bg-white peer-focus:px-1 peer-valid:-top-2.5 peer-valid:text-xs peer-valid:bg-white peer-valid:px-1 z-10 rounded ml-5">
                  Price / night
                </label>
              </div>

              <!-- Rating -->
              <div class="relative group">
                 <div class="absolute inset-y-0 right-0 pr-5 flex items-center pointer-events-none">
                  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation" focusable="false" style="display: block; height: 16px; width: 16px; fill: #ffd700;"><path d="M15.094 1.579l-4.124 8.885-9.86 1.27a1 1 0 0 0-.542 1.736l7.293 6.565-1.965 9.852a1 1 0 0 0 1.483 1.061L16 25.951l8.625 4.997a1 1 0 0 0 1.482-1.06l-1.965-9.853 7.293-6.565a1 1 0 0 0-.541-1.735l-9.86-1.271-4.127-8.885a1 1 0 0 0-1.814 0z" fill-rule="evenodd"></path></svg>
                </div>
                <input
                  type="number"
                  name="rating"
                  id="rating"
                  value="<%= editing ? home.rating : '' %>"
                  placeholder=" Rating (0-5)"
                  required
                  step="0.1"
                  min="0"
                  max="5"
                  class="peer w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:bg-white input-glow text-gray-900 font-bold placeholder-transparent transition-all"
                />
                <label for="rating" class="absolute left-5 top-4 text-gray-400 font-medium transition-all peer-placeholder-shown:text-[16px] peer-placeholder-shown:top-4 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-[#FF385C] peer-focus:bg-white peer-focus:px-1 peer-valid:-top-2.5 peer-valid:text-xs peer-valid:bg-white peer-valid:px-1 z-10 rounded">
                  Rating (0-5)
                </label>
              </div>
            </div>

            <!-- Image URL -->
            <div class="relative group">
              <input
                type="url"
                name="photoUrl"
                id="photoUrl"
                value="<%= editing ? home.photoUrl : '' %>"
                placeholder="URL to a high-resolution photo of your home"
                required
                class="peer w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:bg-white input-glow text-gray-900 font-medium placeholder-transparent transition-all"
              />
              <label for="photoUrl" class="absolute left-5 top-4 text-gray-400 font-medium transition-all peer-placeholder-shown:text-[16px] peer-placeholder-shown:top-4 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-[#FF385C] peer-focus:bg-white peer-focus:px-1 peer-valid:-top-2.5 peer-valid:text-xs peer-valid:bg-white peer-valid:px-1 z-10 rounded">
                High-Resolution Photo URL
              </label>
            <div class="relative group">
              <textarea
                type="text"
                name="description"
                id="description"
                
                placeholder="Describe your home"
                required
                class="peer w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:bg-white input-glow text-gray-900 font-medium placeholder-transparent transition-all mt-5"
              ><%= editing ? home.description : '' %></textarea>
              <label for="description" class="absolute left-5 top-4 text-gray-400 font-medium transition-all peer-placeholder-shown:text-[16px] peer-placeholder-shown:top-4 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-[#FF385C] peer-focus:bg-white peer-focus:px-1 peer-valid:-top-2.5 peer-valid:text-xs peer-valid:bg-white peer-valid:px-1 z-10 rounded mt-5">
                Describe your home
              </label>
              
            </div>
            
          </div>

          <!-- Submit Button -->
          <div class="pt-4">
            <button
              type="submit"
              class="w-full flex justify-center items-center gap-2 bg-gradient-to-r from-[#FF385C] to-[#E31C5F] hover:from-[#E31C5F] hover:to-[#c4173f] text-white font-bold py-4 px-6 rounded-2xl shadow-lg hover:shadow-xl shadow-red-500/30 transition-all duration-300 hover:-translate-y-1 text-lg"
            >
              <%= editing ? "Update Listing" : "Publish Listing" %>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>
          </div>
          
        </form>
      </div>
    </main>

   <%- include ('../partials/footer') %>
  </body>
</html>
