<%- include ('partials/head') %>
  <body class="bg-gray-50 flex flex-col min-h-screen font-sans">
    <%- include ('partials/nav')%>

    <main
      class="flex-grow container mx-auto px-4 py-8 flex flex-col items-center justify-center"
    >
      <div
        class="text-center bg-white p-10 rounded-lg shadow-sm border border-gray-100 max-w-md w-full"
      >
        <h1 class="text-4xl font-bold text-airbnb mb-2">404</h1>
        <p class="text-xl text-gray-800 font-medium mb-4">Page Not Found</p>
        <p class="text-gray-600 mb-8">
          The page you're looking for doesn't exist.
        </p>

        <a
