<%-include ('../partials/head') %>
  
  <body class="bg-gray-50 flex flex-col min-h-screen font-sans">
    <%-include ('../partials/nav') %>
    
    

    <main class="grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
      <!-- Header Section -->
      <div class="mb-6 flex flex-col gap-2">
        <h1 class="text-3xl sm:text-4xl font-semibold text-gray-900 tracking-tight">
          <%= home.houseName %>
        </h1>
        <div class="flex items-center gap-2 text-sm font-medium text-gray-900">
          <div class="flex items-center gap-1">
            <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation" focusable="false" style="display: block; height: 14px; width: 14px; fill: currentcolor;"><path d="M15.094 1.579l-4.124 8.885-9.86 1.27a1 1 0 0 0-.542 1.736l7.293 6.565-1.965 9.852a1 1 0 0 0 1.483 1.061L16 25.951l8.625 4.997a1 1 0 0 0 1.482-1.06l-1.965-9.853 7.293-6.565a1 1 0 0 0-.541-1.735l-9.86-1.271-4.127-8.885a1 1 0 0 0-1.814 0z" fill-rule="evenodd"></path></svg>
            <span class="font-semibold"><%= home.rating ? (Number(home.rating) > 5 ? '5.0' : Number(home.rating).toFixed(1)) : 'New' %></span>
          </div>
          <span class="text-gray-400">•</span>
          <a href="#" class="underline hover:text-gray-600 font-semibold"><%= home.location || 'Location missing' %></a>
          <% if(home.address) { %>
            <span class="text-gray-400">•</span>
            <span class="text-gray-600"><%= home.address %></span>
          <% } %>
        </div>
      </div>

      <!-- Single Hero Image -->
      <div class="mb-10 overflow-hidden relative bg-gray-200 rounded-2xl w-full h-[400px] lg:h-[500px] xl:h-[600px]">
        <img 
          src="<%= home.photoUrl || 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&q=80&w=1200' %>" 
          alt="<%= home.houseName %>"
          class="w-full h-full object-cover"
          onerror="this.src='https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&q=80&w=1200'"
        >
      </div>

      <!-- Main Content & Sidebar Container -->
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-24">
        
        <!-- Left Content (Details) -->
        <div class="lg:w-[60%] flex flex-col gap-8">
          <!-- Host info -->
          <div class="flex justify-between items-center border-b border-gray-200 pb-8">
            <div>
              <h2 class="text-xl sm:text-2xl font-semibold text-gray-900">Entire home hosted by Airbnb Host</h2>
              <div class="text-gray-600 mt-1 flex gap-2 text-sm sm:text-base">
                <span>6 guests</span>
                <span>·</span>
                <span>3 bedrooms</span>
                <span>·</span>
                <span>3 beds</span>
                <span>·</span>
                <span>2 baths</span>
              </div>
            </div>
            <div class="w-14 h-14 bg-gray-200 rounded-full overflow-hidden shrink-0 border border-gray-300">
              <img src="https://ui-avatars.com/api/?name=Host&background=FF385C&color=fff" alt="Host avatar" class="w-full h-full object-cover">
            </div>
          </div>

          <!-- Highlights -->
          <div class="border-b border-gray-200 pb-8 flex flex-col gap-6">
            <div class="flex gap-4">
              <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" style="display: block; height: 24px; width: 24px; fill: currentColor;" aria-hidden="true" role="presentation" focusable="false" class="shrink-0 mt-1"><path d="M26 2a1 1 0 0 1 .993.883L27 3v26a1 1 0 0 1-1.993.117L25 29H7a1 1 0 0 1-.117-1.993L7 27h18V3a1 1 0 0 1 1-1zM12 8a3 3 0 1 1 0 6 3 3 0 0 1 0-6zm0 2a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm12.316-1.5721l-.105.086-6.402 6.026a2 2 0 0 1-2.505.152l-.113-.086-4-3.5a1 1 0 1 1 1.316-1.503l3.33 2.913 5.795-5.454a1 1 0 0 1 1.397 1.366z"></path></svg>
              <div>
                <h3 class="font-semibold text-gray-900 text-lg">Self check-in</h3>
                <p class="text-gray-600 text-[15px]">Check yourself in with the keypad.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" style="display: block; height: 24px; width: 24px; fill: currentColor;" aria-hidden="true" role="presentation" focusable="false" class="shrink-0 mt-1"><path d="M22 2a4 4 0 0 1 3.995 3.8l.005.2h6v2h-6v20a2 2 0 0 1-1.85 1.995L24 30h-2v2h-2v-2H12v2h-2v-2H8a2 2 0 0 1-1.995-1.85L6 28V8H0V6h6V4a4 4 0 0 1 3.8-3.995L10 0h12zm0 2H10a2 2 0 0 0-1.995 1.85L8 4v4h16V4a2 2 0 0 0-1.85-1.995L22 2z"></path></svg>
              <div>
                <h3 class="font-semibold text-gray-900 text-lg">Great location</h3>
                <p class="text-gray-600 text-[15px]">100% of recent guests gave the location a 5-star rating.</p>
              </div>
            </div>
          </div>

          <!-- Description -->
          <div class="border-b border-gray-200 pb-8 text-gray-700 leading-relaxed text-base">
            <p class="mb-4">
              Discover a perfect getaway at <strong><%= home.houseName %></strong>, situated in the elegant neighborhood of <%= home.location %>. This beautifully designed space offers a tranquil escape with all the modern comforts you need for an unforgettable stay.
            </p>
            <p>
               Enjoy coffee with a stunning view, and explore the nearby attractions. Whether you're here for work or leisure, this home provides the ideal base for your adventures. Maximum comfort, space, and convenience all rolled into one.
            </p>
            <button class="mt-6 font-semibold underline decoration-solid decoration-1 underline-offset-2 flex items-center gap-1 hover:text-gray-900 transition-colors text-gray-900">
              Show more
              <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation" focusable="false" style="display: block; fill: none; height: 12px; width: 12px; stroke: currentcolor; stroke-width: 4; overflow: visible;"><g fill="none"><path d="m12 4 11.2928932 11.2928932c.3905243.3905243.3905243 1.0236893 0 1.4142136l-11.2928932 11.2928932"></path></g></svg>
            </button>
          </div>

        </div>

        <!-- Right Content (Sticky Booking Widget) -->
        <div class="lg:w-[40%] relative">
          <div class="sticky top-28 bg-white border border-gray-200 shadow-xl rounded-2xl p-6 flex flex-col">
            
            <div class="flex items-baseline justify-between mb-6">
              <div class="flex items-baseline gap-1">
                <span class="text-2xl font-semibold text-gray-900">₹<%= home.price || '0' %></span>
                <span class="text-gray-600 text-base">night</span>
              </div>
            </div>
            <%-include('../partials/favourites') %>

            <a href="/" class="w-full mt-3 block border border-gray-900 hover:bg-gray-50 text-gray-900 font-semibold py-3.5 rounded-lg text-[16px] transition-colors text-center">
              Browse other homes
            </a>
            
          </div>
        </div>
      </div>
      
    </main>

   <%- include ('../partials/footer') %>
  </body>
</html>
