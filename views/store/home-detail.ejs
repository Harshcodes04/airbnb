<%- include ('../partials/head') %>
  
  <body class="bg-gray-50 flex flex-col min-h-screen font-sans selection:bg-red-100 selection:text-red-900">
    <%- include ('../partials/nav')%>
    
    <% if (!home) { %>
      <main class="grow flex flex-col items-center justify-center p-8 text-center min-h-[60vh] animate-fade-in-up">
        <div class="w-24 h-24 bg-red-50 rounded-full flex items-center justify-center mb-6 animate-float">
          <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation" focusable="false" style="display: block; height: 48px; width: 48px; fill: #FF385C; opacity: 0.5;"><path d="M16 1.98a12 12 0 0 0-11.97 12c0 8.01 11.45 15.7 11.66 15.84a.5.5 0 0 0 .62 0c.2-.14 11.66-7.83 11.66-15.84A12 12 0 0 0 16 1.98zm0 24.81c-4.48-3.66-10.97-10.35-10.97-14.83a11 11 0 0 1 21.94 0c0 4.48-6.49 11.17-10.97 14.83zm0-18.79a6 6 0 1 0 6 6 6 6 0 0 0-6-6zm0 11a5 5 0 1 1 5-5 5 5 0 0 1-5 5z"></path></svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Home Not Found</h1>
        <p class="text-gray-500 mb-8 max-w-sm">We couldn't find the home you're looking for. It might have been removed or the link is broken.</p>
        <a href="/homes" class="inline-flex items-center gap-2 bg-gradient-to-r from-[#FF385C] to-[#E31C5F] hover:from-[#E31C5F] hover:to-[#c4173f] text-white px-8 py-3.5 rounded-full font-bold shadow-lg shadow-red-200 transition-all hover:-translate-y-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to all homes
        </a>
      </main>
    <% } else { %>
      <main class="grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
        
        <!-- Header Section -->
        <div class="mb-6 animate-fade-in-up">
          <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight mb-3 hover:text-[#FF385C] transition-colors"><%= home.houseName %></h1>
          <div class="flex flex-wrap items-center gap-y-2 text-[15px] font-medium text-gray-700">
            <span class="flex items-center gap-1.5 bg-gray-100/80 backdrop-blur-sm px-2.5 py-1 rounded-lg border border-gray-200/60">
              <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation" focusable="false" style="display: block; height: 14px; width: 14px; fill: #ffd700;"><path d="M15.094 1.579l-4.124 8.885-9.86 1.27a1 1 0 0 0-.542 1.736l7.293 6.565-1.965 9.852a1 1 0 0 0 1.483 1.061L16 25.951l8.625 4.997a1 1 0 0 0 1.482-1.06l-1.965-9.853 7.293-6.565a1 1 0 0 0-.541-1.735l-9.86-1.271-4.127-8.885a1 1 0 0 0-1.814 0z" fill-rule="evenodd"></path></svg>
              <span class="font-bold text-gray-900"><%= home.rating ? (Number(home.rating) > 5 ? '5.0' : Number(home.rating).toFixed(1)) : 'New' %></span>
            </span>
            <span class="mx-2 text-gray-400">•</span>
            <a href="#" class="font-semibold underline hover:text-gray-900 transition-colors flex items-center gap-1.5">
              <%= home.location || 'Location missing' %>
            </a>
          </div>
        </div>

        <!-- Premium Hero Image Section -->
        <div class="mb-12 relative rounded-[32px] overflow-hidden group shadow-xl shadow-gray-200/50 block animate-fade-in-up stagger-1">
          <div class="aspect-[16/9] md:aspect-[21/9] w-full img-shimmer relative">
            <img 
              src="<%= home.photoUrl %>" 
              alt="<%= home.houseName %>"
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000 ease-out"
              onload="this.parentElement.classList.remove('img-shimmer')"
              onerror="this.src='https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&q=80&w=1200'"
            >
            <!-- Luxurious Gradient Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-90 transition-opacity duration-500 group-hover:opacity-70 z-10"></div>
            
            <!-- Bottom Left Info in Hero -->
            <div class="absolute bottom-6 left-6 sm:bottom-10 sm:left-10 z-20 text-white">
              <span class="inline-block px-4 py-1.5 bg-white/20 backdrop-blur-md rounded-full text-sm font-bold tracking-wider uppercase mb-3 border border-white/30 shadow-sm">
                Premium Space
              </span>
              <h2 class="text-2xl sm:text-4xl font-extrabold max-w-2xl leading-tight drop-shadow-md">
                Experience the magic of <%= home.location || 'this location' %>
              </h2>
            </div>
          </div>
        </div>

        <!-- Layout Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 relative">
          
          <!-- Left Column (Main Details) -->
          <div class="lg:col-span-2 space-y-10 animate-fade-in-up stagger-2">
            
            <!-- Host Info & Title -->
            <div class="flex justify-between items-start border-b border-gray-200 pb-8">
              <div>
                <h2 class="text-2xl font-bold text-gray-900 mb-2 leading-tight">Entire home hosted by <%= home.hostName || 'a Superhost' %></h2>
                <p class="text-[16px] text-gray-600 flex items-center gap-2">
                  <span><%= home.guests || '16' %> guests</span> <span class="text-gray-300">•</span>
                  <span><%= home.bedrooms || '5' %> bedrooms</span> <span class="text-gray-300">•</span>
                  <span><%= home.beds || '6' %> beds</span> <span class="text-gray-300">•</span>
                  <span><%= home.baths || '5.5' %> baths</span>
                </p>
              </div>
              <div class="w-16 h-16 rounded-full bg-gradient-to-br from-gray-100 to-gray-200 flex-shrink-0 flex items-center justify-center border-2 border-white shadow-md relative group cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-400 group-hover:text-gray-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <div class="absolute -bottom-1 -right-1 bg-[#FF385C] w-5 h-5 rounded-full border-2 border-white flex items-center justify-center">
                  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"  style="display: block; height: 8px; width: 8px; fill: white;"><path d="m15.1 1.58-4.13 8.88-9.86 1.27a1 1 0 0 0-.54 1.74l7.3 6.57-1.97 9.85a1 1 0 0 0 1.48 1.06l8.62-5 8.63 5a1 1 0 0 0 1.48-1.06l-1.97-9.85 7.3-6.57a1 1 0 0 0-.52-1.74l-9.86-1.27-4.13-8.88a1 1 0 0 0-1.83 0z"></path></svg>
                </div>
              </div>
            </div>

            <!-- Features Highlights -->
            <div class="border-b border-gray-200 pb-10 space-y-7">
              <div class="flex gap-5 group">
                <div class="w-10 h-10 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-gray-700 group-hover:text-[#FF385C] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 text-lg">Designed for comfort</h3>
                  <p class="text-gray-500 mt-1 leading-relaxed">Every corner is thoughtfully curated to make you feel right at home.</p>
                </div>
              </div>
              
              <div class="flex gap-5 group">
                <div class="w-10 h-10 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-gray-700 group-hover:text-[#FF385C] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 text-lg">Great location</h3>
                  <p class="text-gray-500 mt-1 leading-relaxed">95% of recent guests gave the location a 5-star rating.</p>
                </div>
              </div>

              <div class="flex gap-5 group">
                <div class="w-10 h-10 mt-1">
                  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-gray-700 group-hover:text-[#FF385C] transition-colors" fill="currentColor" aria-hidden="true" role="presentation" focusable="false"><path d="m11.64 5.23 1.4-1.4 17.68 17.67-1.41 1.42zm-8.35 4 1.41-1.41 11.23 11.22-1.41 1.41zm3.87-7.73A1 1 0 0 0 7 1H2a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h5a1 1 0 0 0 1-1V4.2l3.37 3.38 1.41-1.41L9.4 2.8zM24 2H13v2h11v11h2V3a1 1 0 0 0-1-1z"></path></svg>
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 text-lg">Fast wifi</h3>
                  <p class="text-gray-500 mt-1 leading-relaxed">At 320 Mbps, you can take video calls and stream videos for your whole group.</p>
                </div>
              </div>
            </div>

            <!-- Description -->
             <div class="pb-10">
               <h2 class="text-2xl font-bold text-gray-900 mb-6">About this space</h2>
               <% if (home.address) { %>
                <p class="text-[16px] text-gray-700 leading-relaxed mb-6"><%= home.address %></p>
               <% } %>
               <p class="text-[16px] text-gray-700 leading-relaxed max-w-3xl">
                 Welcome to our stunning <%= home.houseName %>, a perfect blend of modern luxury and cozy comfort nestled in the heart of <%= home.location %>. Whether you're seeking a peaceful retreat or a convenient base camp for your adventures, our space offers everything you need for an unforgettable stay. Relax, unwind, and immerse yourself in an atmosphere designed entirely around your well-being.
               </p>
               <button class="mt-6 font-bold underline flex items-center gap-1 hover:text-gray-600 transition-colors group">
                 Show more
                 <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
               </button>
             </div>
          </div>

          <!-- Right Column (Floating Stats / Favourite Card) -->
          <div class="lg:col-span-1 relative">
            <div class="sticky top-[100px] bg-white border border-gray-200 shadow-xl shadow-gray-200/50 rounded-[28px] p-7 md:p-8 animate-fade-in-up stagger-3">
              
              <!-- Card Header -->
              <div class="flex items-baseline justify-between mb-8">
                <div>
                  <span class="text-2xl font-extrabold text-gray-900">₹<%= home.price || '0' %></span>
                  <span class="text-[16px] text-gray-500 font-medium">/night</span>
                </div>
              </div>
             
             <!-- Fake booking fields (Removed visually by user instruction before, so I will ensure they look like nice decorative elements instead of forms, or just keep it simple) -->
             <div class="bg-gray-50 rounded-2xl border border-gray-200 mb-6 overflow-hidden">
                <div class="flex border-b border-gray-200">
                  <div class="flex-1 p-3 border-r border-gray-200">
                    <div class="text-[10px] font-bold uppercase tracking-wider text-gray-900">Information</div>
                    <div class="text-sm text-gray-500 mt-0.5"><%= home.location %></div>
                  </div>
                  <div class="flex-1 p-3">
                    <div class="text-[10px] font-bold uppercase tracking-wider text-gray-900">Rating</div>
                    <div class="text-sm text-gray-500 mt-0.5"><%= home.rating %> Stars</div>
                  </div>
                </div>
                <div class="w-full p-3">
                    <div class="text-[10px] font-bold uppercase tracking-wider text-gray-900">Status</div>
                    <div class="text-sm text-green-600 font-medium mt-0.5 flex items-center gap-1.5">
                      <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                      Available Now
                    </div>
                  </div>
             </div>

              <!-- Action Button -->
              <%- include('../partials/favourites', { home: home }) %>

              <!-- Info Text below button -->
              <div class="flex flex-col gap-4 mt-6 pt-6 border-t border-gray-100">
                 <div class="flex justify-between items-center text-[15px] font-medium text-gray-600">
                   <span>Weekly discount</span>
                   <span class="text-green-600">-₹500</span>
                 </div>
                 <div class="flex justify-between items-center text-[15px] font-medium text-gray-600">
                   <span>Cleaning fee</span>
                   <span>₹150</span>
                 </div>
                 <div class="flex justify-between items-center text-lg font-bold text-gray-900 pt-4 border-t border-gray-100 mt-2">
                   <span>Total before taxes</span>
                   <span>₹<%= (Number(home.price || 0) + 150 - 500) > 0 ? (Number(home.price || 0) + 150 - 500) : home.price %></span>
                 </div>
              </div>
            </div>
          </div>
          
        </div>
      </main>
    <% } %>
    
    <%- include ('../partials/footer') %>
  </body>
</html>
